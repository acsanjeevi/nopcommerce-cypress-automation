# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to secured.env and fill in your values.
# secured.env is gitignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# App URLs — nopCommerce 4.70.5 running via Docker on port 8080
CYPRESS_BASE_URL=http://localhost:8080
CYPRESS_ADMIN_URL=http://localhost:8080

# Storefront customer account (registered in nopCommerce)
CYPRESS_CUSTOMER_EMAIL=your-customer@email.com
CYPRESS_CUSTOMER_PASSWORD=YourCustomerPassword
CYPRESS_CUSTOMER_USERNAME=YourFirstName

# nopCommerce admin panel credentials
CYPRESS_ADMIN_EMAIL=admin@yourstore.com
CYPRESS_ADMIN_PASSWORD=admin

# Framework settings (safe to leave as-is)
CYPRESS_ENCRYPTION_KEY=ecommerce-aes-secret-key-2026
CYPRESS_ROLE=admin
CYPRESS_REPORT_FILENAME=[name]-report

# Docker — PostgreSQL connection (used by nopCommerce internally via docker-compose)
# DB_HOST=postgres  DB_NAME=nopcommerce  DB_USER=nopuser  DB_PASS=nopassword  DB_PORT=5432
