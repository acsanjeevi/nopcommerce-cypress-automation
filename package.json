{
  "name": "ecommerce-cypress-automation",
  "version": "1.0.1",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "ts-node run-tests.ts role=admin",
    "cleanReports": "node clean-reports.mjs",
    "dataCleanUp": "cross-env CYPRESS_SKIP_VERIFY=true cypress run --spec cypress/e2e/deleterecords/wipeout-allcreatedrecords.cy.ts --browser chrome --headed",
    "cleanUpDataAndReports": "npm run dataCleanUp && npm run cleanReports",
    "mochawesome-report-merge": "mochawesome-merge cypress/reports/.jsons/*.json --output cypress/reports/mergedjsonreport/report.json",
    "finalreport": "marge cypress/reports/mergedjsonreport/report.json --inline -f ECommerce_TestReport -o cypress/reports/",
    "mergeAndGenerateFinalReport": "npm run mochawesome-report-merge && npm run finalreport",
    "runTestsAsAdmin": "npm run cleanReports && ts-node run-tests.ts role=admin",
    "runProductionTest": "npm run cleanReports && cross-env CYPRESS_ROLE=admin ts-node run-tests.ts role=admin"
  },
  "devDependencies": {
    "@cypress/grep": "^4.1.0",
    "@types/crypto-js": "^4.2.0",
    "@types/jsonwebtoken": "^9.0.2",
    "cross-env": "^10.1.0",
    "crypto-js": "^4.2.0",
    "cypress": "^15.15.0",
    "cypress-mochawesome-reporter": "^3.8.2",
    "cypress-wait-until": "^3.0.2",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "jsonwebtoken": "^9.0.2",
    "marge": "^1.0.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "nodemailer": "^7.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  }
}
